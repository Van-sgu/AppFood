<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FoodStreet.ListPage"
    Title="Danh sách"
    BackgroundColor="#f5f5f5">

    <VerticalStackLayout Padding="10" Spacing="10">

        <!-- SEARCH -->
        <Frame CornerRadius="25" Padding="10" BackgroundColor="White">
            <Grid ColumnDefinitions="Auto,*">
                <Label Text="🔍" FontSize="18"/>
                <Entry x:Name="searchEntry"
                       Grid.Column="1"
                       Placeholder="Search..."
                       TextChanged="OnSearchChanged"/>
            </Grid>
        </Frame>

        <!-- LIST -->
        <CollectionView x:Name="listView" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Frame CornerRadius="15"
                           Padding="10"
                           Margin="0,5"
                           BackgroundColor="White"
                           HasShadow="True">

                        <Grid ColumnDefinitions="90,*,Auto">

                            <!-- IMAGE -->
                            <Image Source="{Binding Image}"
                                   HeightRequest="80"
                                   WidthRequest="90"
                                   Aspect="AspectFill"/>

                            <!-- INFO -->
                            <VerticalStackLayout Grid.Column="1" Padding="10,0" Spacing="3">
                                <Label Text="{Binding Name}" 
                                       FontAttributes="Bold"
                                       FontSize="14"/>

                                <Label Text="{Binding Description}" 
                                       FontSize="12"
                                       TextColor="Gray"/>

                                <!-- RATING -->
                                <Label Text="{Binding RatingText}"
                                       FontSize="12"
                                       TextColor="Gray"/>
                            </VerticalStackLayout>

                            <!-- BUTTONS -->
                            <VerticalStackLayout Grid.Column="2" Spacing="5">

                                <Button Text="Chi tiết"
                                        FontSize="12"
                                        BackgroundColor="#ffd166"
                                        TextColor="Black"
                                        Clicked="OnDetailClicked"
                                        CommandParameter="{Binding .}"/>

                                <Button Text="Bản đồ"
                                        FontSize="12"
                                        BackgroundColor="#06d6a0"
                                        TextColor="White"
                                        Clicked="OnMapClicked"
                                        CommandParameter="{Binding .}"/>

                            </VerticalStackLayout>

                        </Grid>

                    </Frame>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>

</ContentPage>