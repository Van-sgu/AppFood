<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
    x:Class="FoodStreet.MainPage"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- HEADER -->
        <Grid BackgroundColor="#2ecc71" Padding="15" Row="0">
            <VerticalStackLayout>
                <Label Text="Phố Ẩm Thực"
                       FontSize="20"
                       TextColor="White"
                       FontAttributes="Bold"/>
                <Label Text="Thuyết Minh Tự Động"
                       FontSize="14"
                       TextColor="White"/>
            </VerticalStackLayout>
        </Grid>

        <!-- MAP -->
        <maps:Map x:Name="map"
                  Grid.Row="1"
                  IsShowingUser="True"
                  MapType="Street"/>

        <!-- BOTTOM BAR -->
        <Grid Grid.Row="2"
              BackgroundColor="#2ecc71"
              Padding="10"
              ColumnDefinitions="*,*">

            <VerticalStackLayout HorizontalOptions="Center">
                <Image Source="list_icon.png" HeightRequest="24"/>
                <Button  Text="Danh sách"
                       TextColor="White"
                       FontSize="12"
                       Clicked = "OnShowListClicked"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnShowListClicked"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                <Image Source="settings_icon.png" HeightRequest="24"/>
                <Button Text="Cài đặt"
                       TextColor="White"
                       FontSize="12"
                       Clicked = "OnShowListClicked"/>
            </VerticalStackLayout>

        </Grid>

    </Grid>
</ContentPage>