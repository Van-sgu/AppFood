<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FoodStreet.Models"
             x:Class="FoodStreet.Pages.DetailPoi"
             Title="Chi tiết địa điểm">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label x:Name="lblTitle"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#2c3e50"
                   HorizontalOptions="Center"/>

            <BoxView HeightRequest="1" Color="LightGray" />

            <Label x:Name="lblDescription"
                   FontSize="18"
                   LineHeight="1.5"
                   TextColor="#34495e"/>

            <BoxView HeightRequest="1" Color="Transparent" VerticalOptions="FillAndExpand" />

            <Button x:Name="btnSpeak"
                    Text="🔊 Nghe thuyết minh"
                    FontSize="18"
                    BackgroundColor="#3498db"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="60"
                    Clicked="OnSpeakClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>