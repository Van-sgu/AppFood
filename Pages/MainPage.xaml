<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
             xmlns:models="clr-namespace:FoodStreet.Models"
             
             x:Class="FoodStreet.Pages.MainPage"
             Title="Danh sách các địa điểm"
             >

    <CollectionView x:Name="MyCollectionView" Margin="10">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:POI">
                <Border StrokeShape="RoundRectangle 15"
                    Stroke="LightGray"
                    Margin="0,8"
                    Padding="10"
                    BackgroundColor="White">

                    <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="120, *">
                        <Image Grid.Column="0" Grid.RowSpan="2"
                           Source="{Binding ImagePath}" 
                           Aspect="AspectFill"
                           HeightRequest="100"
                           WidthRequest="100"
                           VerticalOptions="Center"
                           HorizontalOptions="Center">
                            <Image.Clip>
                                <RoundRectangleGeometry CornerRadius="10" Rect="0,0,100,100"/>
                            </Image.Clip>
                        </Image>

                        <Label Grid.Column="1" Grid.Row="0"
                           Text="{Binding Name}"
                           FontAttributes="Bold" 
                           FontSize="18"
                           TextColor="#D600AA"
                           VerticalOptions="Center"
                           Margin="10,0,0,0"/>

                        <HorizontalStackLayout Grid.Column="1" Grid.Row="1" 
                                           Spacing="10" Margin="10,10,0,0">

                            <Button Text="Chi tiết"
                                FontSize="12"
                                HeightRequest="35"
                                BackgroundColor="#3498db"
                                Clicked="DetailClicked"
                                CommandParameter="{Binding .}"/>

                            <Button Text="Thuyết minh"
                                FontSize="12"
                                HeightRequest="35"
                                BackgroundColor="#2ecc71"
                                Clicked="NarrateClicked"
                                CommandParameter="{Binding .}"/>
                        </HorizontalStackLayout>
                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>