<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodStreet.Pages.SettingsPage" 
             Title="Cài đặt"
             BackgroundColor="#f5f5f5">
    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="15">

            <Frame CornerRadius="15" Padding="15" BackgroundColor="White">
                <VerticalStackLayout>
                    <Label x:Name="volumeLabel" Text="Âm lượng: 100%" />
                    <Slider x:Name="volumeSlider" Minimum="0" Maximum="100" Value="100" ValueChanged="OnVolumeChanged"/>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="15" Padding="15" BackgroundColor="White">
                <VerticalStackLayout>
                    <Label x:Name="speedLabel" Text="Tốc độ giọng nói: 1.0x"/>
                    <Slider x:Name="speedSlider" Minimum="0.5" Maximum="2" Value="1"
                            ValueChanged="OnSpeedChanged"/>
                </VerticalStackLayout>
            </Frame>

            <Label Text="Ngôn ngữ" FontAttributes="Bold"/>

            <Frame CornerRadius="15" Padding="15" BackgroundColor="White">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Label Text="🌐" FontSize="20" VerticalOptions="Center"/>
                    <VerticalStackLayout Grid.Column="1" Margin="10,0">
                        <Label Text="Ngôn ngữ hiện tại" FontSize="14"/>
                        <Label x:Name="languageLabel" Text="Tiếng Việt" FontSize="12" TextColor="Gray"/>
                    </VerticalStackLayout>

                    <Button Text="Sửa" 
                            Grid.Column="2"
                            Clicked="OnLanguageClicked"/>
                </Grid>
            </Frame>

            <Button Text="Reset Cài Đặt"
                    Margin="0,20"
                    BorderColor="Blue"
                    BorderWidth="1"
                    TextColor="Blue"
                    BackgroundColor="Transparent"
                    Clicked="OnResetClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>